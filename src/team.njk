---
layout: base.njk
title: DSN 2027 Team
description: Current DSN 2027 organizing team planning information.
permalink: /team/
---

<section class="section page-title" aria-labelledby="page-title">
  <p class="section-kicker">Team</p>
  <h1 id="page-title">Organizing roles</h1>
  <p>Roles listed here reflect the current planning note and will be updated as appointments are confirmed.</p>
</section>

<section class="section" aria-label="Organizing role list">
  <div class="role-groups">
    {% for group in conference.roles %}
      <section class="role-group" aria-labelledby="role-group-{{ loop.index }}">
        <h2 id="role-group-{{ loop.index }}">{{ group.group }}</h2>
        <div class="role-list">
          {% for item in group.entries %}
            <article class="role-item">
              <div>
                <h3>{{ item.role }}</h3>
                {% if item.people.length %}
                  <p>{{ item.people | join(", ") }}</p>
                {% else %}
                  <p>To be announced</p>
                {% endif %}
              </div>
              <span class="pill">{{ item.status }}</span>
            </article>
          {% endfor %}
        </div>
      </section>
    {% endfor %}
  </div>
</section>

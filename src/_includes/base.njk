<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="description" content="{{ description or conference.subtitle + ' in ' + conference.location }}">
    <title>{{ title or conference.title }}</title>
    <link rel="icon" href="/assets/favicon.png" type="image/png" sizes="512x512">
    <link rel="icon" href="/assets/favicon-32.png" type="image/png" sizes="32x32">
    <link rel="apple-touch-icon" href="/assets/apple-touch-icon.png">
    <link rel="preload" href="/assets/berlin-brandenburg-gate.jpg" as="image">
    <link rel="stylesheet" href="/assets/styles.css">
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <aside class="site-sidebar" aria-label="Conference navigation">
      <a class="brand" href="/" aria-label="{{ conference.title }} home">
        <img class="brand-logo" src="/assets/logo.png" alt="" width="120" height="101">
        <span>
          <span class="brand-title">{{ conference.title }}</span>
          <span class="brand-subtitle">{{ conference.location }}</span>
        </span>
      </a>
      <div class="sidebar-summary">
        <strong>{{ conference.subtitle }}</strong>
        <span>{{ conference.location }}</span>
        <span>{{ conference.dates }}</span>
      </div>
      <nav class="site-nav" aria-label="Primary navigation">
        <a href="/" {% if page.url == "/" %}aria-current="page"{% endif %}>Home</a>
        <a href="/call-for-contributions/" {% if page.url == "/call-for-contributions/" %}aria-current="page"{% endif %}>Call for Contributions</a>
        <a href="/workshops/" {% if page.url == "/workshops/" %}aria-current="page"{% endif %}>Workshops</a>
        <a href="/committees/" {% if page.url == "/committees/" %}aria-current="page"{% endif %}>Committees</a>
        <a href="/conference-program/" {% if page.url == "/conference-program/" %}aria-current="page"{% endif %}>Conference Program</a>
        <a href="/sponsors/" {% if page.url == "/sponsors/" %}aria-current="page"{% endif %}>Sponsors</a>
        <a href="/previous-conferences/" {% if page.url == "/previous-conferences/" %}aria-current="page"{% endif %}>Previous DSN Conferences</a>
      </nav>
    </aside>
    <div class="page-shell">
      <main id="main">
        {{ content | safe }}
      </main>
      <footer class="site-footer">
        <p>{{ conference.title }} · {{ conference.location }} · {{ conference.dates }}</p>
        <p>
          Photo:
          <a href="https://commons.wikimedia.org/wiki/File:Berlin-Brandenburg_Gate_overview.jpg">Berlin-Brandenburg Gate overview</a>
          by Cezary p at Polish Wikipedia, available under CC BY-SA 3.0 or compatible licenses.
        </p>
      </footer>
    </div>
  </body>
</html>

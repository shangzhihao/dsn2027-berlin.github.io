<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="description" content="{{ description or conference.subtitle + ' in ' + conference.location }}">
    <title>{{ title or conference.title }}</title>
    <link rel="icon" href="/assets/logo.png" type="image/png" sizes="512x512">
    <link rel="apple-touch-icon" href="/assets/logo.png">
    <link rel="preload" href="/assets/berlin-brandenburg-gate.jpg" as="image">
    <link rel="stylesheet" href="/assets/styles.css">
  </head>
  <body class="site-body">
    <a class="skip-link" href="#main">Skip to content</a>
    <aside class="site-sidebar" id="site-sidebar" aria-label="Conference navigation">
      <a class="mobile-close" href="#main" aria-label="Close menu">×</a>
      <a class="brand" href="/" aria-label="{{ conference.title }} home">
        <img class="brand-logo" src="/assets/logo.png" alt="" width="120" height="101">
      </a>
      <div class="sidebar-summary">
        <strong>{{ conference.location }}</strong>
        <span>{{ conference.dates }}</span>
      </div>
      <nav class="site-nav" aria-label="Primary navigation">
        {% for item in navigation.items %}
          {% if item.children %}
            <details class="nav-group" {% if page.url == item.url or (item.activePrefix and page.url.startsWith(item.activePrefix)) or (item.activeUrls and item.activeUrls.includes(page.url)) %}open{% endif %}>
              <summary>{{ item.title }}</summary>
              <div class="nav-children">
                {% for child in item.children %}
                  <a href="{{ child.url }}" {% if page.url == child.url %}aria-current="page"{% endif %}>{{ child.title }}</a>
                {% endfor %}
              </div>
            </details>
          {% else %}
            <a href="{{ item.url }}" {% if page.url == item.url %}aria-current="page"{% endif %}>{{ item.title }}</a>
          {% endif %}
        {% endfor %}
      </nav>
    </aside>
    <div class="page-shell">
      <header class="mobile-header">
        <a class="menu-button" href="#site-sidebar" aria-label="Open menu">☰</a>
        <a href="/" aria-label="{{ conference.title }} home">
          <img src="/assets/logo.png" alt="" width="65" height="51">
        </a>
      </header>
      <main id="main">
        {{ content | safe }}
      </main>
      <footer class="site-footer">
        <p>{{ conference.title }} · {{ conference.location }} · {{ conference.dates }}</p>
        {% if page.url == "/" %}
          <p>
            Photo:
            <a href="https://commons.wikimedia.org/wiki/File:Berlin-Brandenburg_Gate_overview.jpg">Berlin-Brandenburg Gate overview</a>
            by Cezary p at Polish Wikipedia, available under CC BY-SA 3.0 or compatible licenses.
          </p>
        {% endif %}
      </footer>
    </div>
  </body>
</html>
